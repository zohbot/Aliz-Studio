NEXT_PUBLIC_SITE_URL=http://localhost:3000
ALIZ_DATA_BACKEND=file
# Allowed values: file, demo, supabase. Defaults to file when unset.
# Supabase is not active until the server-side adapter is implemented/configured.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
BOOKING_TIMEZONE=America/New_York
DEPOSIT_HOLD_MINUTES=20

# Square
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_VERIFY=false
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# Notifications
OWNER_NOTIFICATION_EMAIL=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_SMS_NUMBER=

# Owner dashboard auth
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_NAME=
OWNER_SESSION_SECRET=

# Local demo only. Keep false for shared, staging, and production deployments.
ALIZ_ALLOW_LOCAL_DEMO_AUTH=false
ALIZ_REQUIRE_PRODUCTION_SECRETS=true
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false
